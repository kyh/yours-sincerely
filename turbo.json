{
  "$schema": "https://turborepo.org/schema.json",
  "ui": "tui",
  "tasks": {
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "dependsOn": ["^dev"],
      "cache": false,
      "persistent": false
    },
    "typecheck": {
      "dependsOn": ["^topo", "^build"],
      "outputs": [".cache/tsbuildinfo.json"]
    },
    "test": {
      "dependsOn": ["^topo", "^build"],
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "//#clean": {
      "cache": false
    }
  },
  "globalEnv": [
    "COOKIE_SECRET",
    "COOKIE_SECRET_LEGACY",
    "POSTGRES_URL",
    "NEXT_PUBLIC_SUPABASE_URL",
    "KNOCK_API_KEY",
    "KNOCK_SIGNING_KEY",
    "NEXT_PUBLIC_KNOCK_PUBLIC_API_KEY",
    "NEXT_PUBLIC_KNOCK_FEED_CHANNEL_ID",
    "NEXT_PUBLIC_KNOCK_EXPO_CHANNEL_ID",
    "RESEND_API_KEY",
    "EXPO_PUBLIC_API_URL",
    "EXPO_PUBLIC_API_PORT",
    "GOOGLE_SERVICES_JSON",
    "PORT"
  ],
  "globalPassThroughEnv": [
    "NODE_ENV",
    "CI",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL",
    "npm_lifecycle_event"
  ]
}
