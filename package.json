{
  "name": "yours-sincerely",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean-workspaces": "turbo run clean",
    "db-supabase": "pnpm -F db supabase",
    "db-start": "pnpm -F db start",
    "db-stop": "pnpm -F db stop",
    "db-reset": "pnpm -F db reset",
    "db-push": "pnpm -F db push",
    "db-push-remote": "pnpm -F db push-remote",
    "dev": "turbo watch dev --continue",
    "dev-web": "turbo watch dev -F @repo/web...",
    "dev-mobile-ios": "pnpm -F mobile ios",
    "dev-mobile-android": "pnpm -F mobile android",
    "lint": "oxlint --report-unused-disable-directives",
    "typecheck": "turbo run typecheck",
    "gen-ui": "pnpm -F ui gen-ui",
    "format": "oxfmt",
    "lint-fix": "oxlint --fix",
    "format-fix": "oxfmt --write"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.52.0",
    "tsx": "^4.21.0",
    "turbo": "^2.8.15",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.32.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "supabase"
    ]
  }
}
