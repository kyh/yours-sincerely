{
  "name": "@repo/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "tsc --noEmit",
    "supabase": "pnpm with-env supabase",
    "drizzle:kit": "pnpm with-env drizzle-kit",
    "seed": "pnpm with-env tsx src/seed/initial.ts",
    "start": "supabase status || supabase start",
    "stop": "supabase stop",
    "reset": "supabase db reset",
    "status": "supabase status",
    "db:test": "supabase db test",
    "push": "pnpm with-env drizzle-kit push",
    "push:remote": "dotenv -e ../../.env.production.local -- drizzle-kit push",
    "generate": "pnpm with-env drizzle-kit generate",
    "migrate": "pnpm with-env drizzle-kit migrate",
    "studio": "pnpm with-env drizzle-kit studio",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "postgres": "^3.4.9",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@kyh/tsconfig": "catalog:",
    "@types/node": "catalog:",
    "drizzle-kit": "^0.31.10",
    "supabase": "^2.109.1",
    "typescript": "catalog:"
  }
}
