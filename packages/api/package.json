{
  "name": "@repo/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "test": "tsc -p tsconfig.test.json && node --test src/**/*.test.ts",
    "test:db": "RUN_DB_TESTS=1 tsc -p tsconfig.test.json && RUN_DB_TESTS=1 tsx --test src/**/*.integration.ts",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@knocklabs/node": "^1.32.0",
    "@repo/contracts": "workspace:^",
    "@repo/db": "workspace:^",
    "@trpc/server": "catalog:",
    "bcryptjs": "^3.0.3",
    "cookie-signature": "^1.2.2",
    "drizzle-orm": "^0.45.2",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "resend": "^6.17.2",
    "superjson": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@kyh/tsconfig": "catalog:",
    "@types/cookie-signature": "^1.1.2",
    "@types/node": "catalog:",
    "tsx": "^4.23.0",
    "typescript": "catalog:"
  }
}
