# Sessions
# Keep the current production signer in COOKIE_SECRET. When rotating it,
# preserve the previous signer in the comma-separated legacy list.
#
# COOKIE_SECRET is REQUIRED in every environment except NODE_ENV=development and
# NODE_ENV=test, which fall back to a public dev constant. Anything else — a
# preview deploy, staging, an unset NODE_ENV — fails to boot without it, because
# the session cookie IS the user id and signing it with a public constant is an
# authentication bypass. Minimum length: 32 characters.
#   Generate one with: openssl rand -base64 32
#
# COOKIE_SECRET_LEGACY is accepted for VERIFICATION ONLY, permanently, so
# rotating the signer never logs anyone out. Move the old COOKIE_SECRET here
# before swapping in a new one. Do not remove it.
COOKIE_SECRET=""
COOKIE_SECRET_LEGACY=""

# Database
# You can get these by creating a project in Supabase and then adding a itegration with vercel
NEXT_PUBLIC_SUPABASE_URL=""
POSTGRES_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Notifications
KNOCK_API_KEY=""
KNOCK_SIGNING_KEY=""
NEXT_PUBLIC_KNOCK_PUBLIC_API_KEY=""
NEXT_PUBLIC_KNOCK_FEED_CHANNEL_ID=""
NEXT_PUBLIC_KNOCK_EXPO_CHANNEL_ID=""
RESEND_API_KEY=""

# Firebase app config file for Android package com.kyh.yourssincerely
GOOGLE_SERVICES_JSON=""

# Expo dev client — where the native app looks for the API.
# Leave blank to use the LAN default; see docs/phone-testing.md.
EXPO_PUBLIC_API_URL=""
EXPO_PUBLIC_API_PORT=""
